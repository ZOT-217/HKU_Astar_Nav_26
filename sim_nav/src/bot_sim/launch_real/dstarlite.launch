<launch>
    <!-- Stage 2: dynamic-map topic is overridable by the parent launch.
         Default `/grid` keeps legacy behavior (dbscan publisher; currently
         disabled). Pass `dynamic_map_topic_name:=/rog_grid` to consume the
         ROG-Map bridge instead. -->
    <arg name="dynamic_map_topic_name" default="/grid"/>

    <node pkg="bot_sim" type="dstarlite" name="dstarlite" >
        <param name="map_topic_name" value="/map" />
        <param name="map_frame_name" value="map" />
        <param name="robot_frame_name" value="virtual_frame" />
        <!-- <param name="robot_frame_name" value="virtual_frame" /> -->
        <param name="dynamic_map_topic_name" value="$(arg dynamic_map_topic_name)" />
        <param name="goal_topic_name" value="/clicked_point" />
        
        <!-- Params for edge cost (sharpened so planner avoids inflated cells)
             At op=100 (hard wall): edge cost ~40.5x baseline
             At op=60 (soft rim):   edge cost ~5x   baseline
             At op=20 (free):       edge cost ~0.5x baseline -->
        <param name="x0_grid" type="double" value="70" />
        <param name="k_grid" type="double" value="0.2" />
        <param name="L_grid" type="double" value="80" />
        
        <!-- Params for velocity cost -->
        <param name="x0_velocity" type="double" value="130" />
        <param name="k_velocity" type="double" value="-0.25" />
        <param name="L_velocity" type="double" value="1.5" />

        <!-- Params for velocity decrease when reaching goal -->
        <param name="start_decrease_dis" type="double" value="2" />
        <param name="min_velocity_rate" type="double" value="0.2" />

           <!-- PID velocity tracking. D*-Lite still plans the desired direction;
               PID compares that desired body-frame velocity with TF-estimated
               body-frame velocity and smooths/corrects /cmd_vel. Raw planner
               output is also published at /dstarlite/raw_cmd_vel. -->
           <param name="pid_enabled" type="bool" value="true" />
           <param name="pid_feedforward" type="double" value="1.0" />
           <param name="pid_kp_x" type="double" value="0.35" />
           <param name="pid_ki_x" type="double" value="0.0" />
           <param name="pid_kd_x" type="double" value="0.02" />
           <param name="pid_kp_y" type="double" value="0.35" />
           <param name="pid_ki_y" type="double" value="0.0" />
           <param name="pid_kd_y" type="double" value="0.02" />
           <param name="pid_integral_limit" type="double" value="0.5" />
           <param name="pid_output_limit" type="double" value="1.5" />
           <param name="pid_accel_limit" type="double" value="2.0" />
           <param name="pid_deadband" type="double" value="0.03" />
           <param name="pid_feedback_timeout" type="double" value="0.25" />
           <param name="pid_reset_on_stop" type="bool" value="true" />
    </node>

    <node pkg="bot_sim" type="cmd_vel_marker" name="cmd_vel_marker">
        <param name="cmd_vel_topic" value="/cmd_vel" />
        <param name="marker_topic" value="/cmd_vel_marker" />
        <param name="frame_id" value="virtual_frame" />
        <param name="linear_scale" type="double" value="1.0" />
    </node>
</launch>