<!-- -->
<launch>
<arg name="old_nav_root" default="/home/sentry_train_test/AstarTraining/Old_nav" />
<arg name="pcd_directory" default="$(arg old_nav_root)/sim_nav/src/hdl_graph_slam/map/" />
<arg name="pcd_name" default="innowing" />
<node pkg="pcd2pgm" name="pcd2pgm" type="pcd2pgm" output="screen">
<!-- 存放pcd文件的路径-->
<param name="file_directory" value= "$(arg pcd_directory)" />
<!-- pcd文件名称-->
<param name="file_name" value= "$(arg pcd_name)" />
<!-- 选取的范围　最小的高度-->
<param name="thre_z_min" value= "-2.0" />
<!-- 选取的范围　最大的高度-->
<param name="thre_z_max" value= "4" />
<!--0 选取高度范围内的，１选取高度范围外的-->
<param name="flag_pass_through" value= "0" />
<!-- 半径滤波的半径-->
<param name="thre_radius" value= "0.2" />
<!-- 半径滤波的要求点数个数-->
<param name="thres_point_count" value= "5" />
<!-- 存储的栅格map的分辨率-->
<param name="map_resolution" value= "0.05" />
<!-- 转换后发布的二维地图的topic，默认使用map即可，可使用map_server保存-->
<param name="map_topic_name" value= "map" />
<param name="max_accept_delta_z" value= "0.05" />
</node>

</launch>
