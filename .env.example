# Optional proxy settings used by docker compose during build and runtime.
# For Docker Desktop image pulls, also configure the proxy in Docker Desktop settings.
HTTP_PROXY=http://host.docker.internal:7890
HTTPS_PROXY=http://host.docker.internal:7890
NO_PROXY=localhost,127.0.0.1,::1

http_proxy=http://host.docker.internal:7890
https_proxy=http://host.docker.internal:7890
no_proxy=localhost,127.0.0.1,::1

# Optional: point the base image at a reachable mirror/private registry copy.
# ROS_BASE_IMAGE=osrf/ros:noetic-desktop-full
